generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArticleCategory {
  NEWS
  STORY
  PRESS
  BLOG
}

enum GalleryLayout {
  GRID
  MASONRY
  SLIDESHOW
}

enum TeamCategory {
  BOARD
  LEADERSHIP
  STAFF
  VOLUNTEERS
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens      RefreshToken[]
  PasswordResetToken PasswordResetToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Article {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  excerpt     String
  content     String
  coverImage  String?
  category    ArticleCategory
  status      Status          @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([category])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String?
  eventDate   DateTime
  endDate     DateTime?
  location    String
  isOnline    Boolean   @default(false)
  meetingLink String?
  status      Status    @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([eventDate])
}

model Gallery {
  id          String        @id @default(cuid())
  title       String
  images      Json
  layout      GalleryLayout @default(GRID)
  status      Status        @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

model TeamMember {
  id           String       @id @default(cuid())
  name         String
  role         String
  bio          String
  photo        String?
  linkedin     String?
  twitter      String?
  category     TeamCategory
  displayOrder Int          @default(0)
  status       Status       @default(DRAFT)
  publishedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([category])
}

model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  verified    Boolean  @default(false)
  verifyToken String?
  createdAt   DateTime @default(now())

  @@index([verified])
}

model NewsletterCampaign {
  id        String   @id @default(cuid())
  subject   String
  content   String
  createdAt DateTime @default(now())
}

model NewsletterSend {
  id         String   @id @default(cuid())
  campaignId String?
  email      String
  sentAt     DateTime @default(now())
  subject    String
  content    String

  @@index([campaignId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
}
